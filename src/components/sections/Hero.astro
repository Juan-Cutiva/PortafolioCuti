---
import Button from '@components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getLocaleFromUrl, getLocaleUrl, useTranslations, type HeroWord } from '@/i18n/ui';

const locale = getLocaleFromUrl(Astro.url);
const { t, tWords } = useTranslations(locale);

// Avatar: si existe `public/images/me.jpg` se usa; si no, placeholder con iniciales.
const photoSrc = '/images/me.jpg';
const photoExists = existsSync(join(process.cwd(), 'public', photoSrc));

function localizedHref(href: string): string {
	if (href.endsWith('.pdf')) return href;
	return getLocaleUrl(href, locale);
}

// Normaliza a la forma `{text, tone?, glue?}` para el typewriter.
function normalizeWord(word: string | HeroWord): HeroWord {
	return typeof word === 'string' ? { text: word } : word;
}
const words = tWords().map(normalizeWord);
---

<section
	id="hero"
	aria-labelledby="hero-title"
	class="relative mx-auto flex min-h-[calc(100svh-var(--header-h))] max-w-5xl flex-col justify-center px-5 py-20 sm:px-6 sm:py-24"
>
	<div class="hero-avatar mb-10 opacity-0 sm:mb-12" data-reveal>
		<span aria-hidden="true" class="avatar-glow"></span>
		<a
			href={getLocaleUrl('/sobre-mi', locale)}
			aria-label={t('hero.avatarLink')}
			class="avatar-link focus-visible:outline-ring rounded-full focus-visible:outline-2 focus-visible:outline-offset-4"
		>
			{
				photoExists ? (
					<img
						src={photoSrc}
						alt={t('hero.avatarAlt')}
						width="160"
						height="160"
						loading="eager"
						fetchpriority="high"
						class="avatar-img"
					/>
				) : (
					<div class="avatar-fallback" aria-hidden="true">
						<span>JC</span>
					</div>
				)
			}
		</a>
	</div>

	<p data-reveal class="text-eyebrow text-primary opacity-0">{t('hero.eyebrow')}</p>

	<h1
		id="hero-title"
		class="text-display-1 text-foreground mt-5 text-balance"
		aria-label={t('hero.titleAria')}
	>
		{
			words.map((word) => {
				const toneClass =
					word.tone === 'primary' ? 'text-primary' : word.tone === 'accent' ? 'text-accent' : '';
				const chars = Array.from(word.text);
				return (
					<span
						class:list={['hero-word', toneClass, word.glue && 'hero-word--glue']}
						aria-hidden="true"
					>
						{chars.map((char) => (
							<span class="hero-char">{char}</span>
						))}
					</span>
				);
			})
		}<span class="hero-cursor" aria-hidden="true"></span>
	</h1>

	<p data-reveal class="text-lede text-muted mt-8 max-w-[62ch] text-pretty opacity-0">
		{t('hero.lede')}
	</p>

	<div data-reveal class="mt-10 flex flex-wrap items-center gap-3 opacity-0">
		<Button as="a" href={localizedHref('/#projects')} variant="primary" size="md">
			{t('hero.ctaProjects')}
			<Icon name="lucide:arrow-down" class="h-4 w-4" aria-hidden="true" />
		</Button>
		<Button as="a" href={localizedHref('/contact')} variant="secondary" size="md">
			{t('hero.ctaContact')}
		</Button>
		<Button as="a" href="/juan-cutiva-cv.pdf" variant="accent" size="md" download>
			<Icon name="lucide:download" class="h-4 w-4" aria-hidden="true" />
			{t('hero.ctaCv')}
		</Button>
	</div>

	<div
		aria-hidden="true"
		class="text-subtle pointer-events-none absolute inset-x-0 bottom-6 hidden justify-center md:flex"
	>
		<span class="text-eyebrow">{t('hero.scroll')}</span>
	</div>
</section>

<style>
	.hero-avatar {
		position: relative;
		display: inline-flex;
		width: clamp(7rem, 9vw + 4rem, 10rem);
		height: clamp(7rem, 9vw + 4rem, 10rem);
	}

	/* Wrapper link sin fondo para no romper la sombra circular del avatar. */
	.avatar-link {
		position: relative;
		z-index: 1;
		display: inline-flex;
		width: 100%;
		height: 100%;
	}

	.avatar-glow {
		position: absolute;
		inset: -14%;
		border-radius: 9999px;
		background: color-mix(in oklab, var(--color-primary) 28%, transparent);
		filter: blur(28px);
		z-index: 0;
		opacity: 0.65;
		pointer-events: none;
		transition: opacity 300ms ease;
	}

	.avatar-img,
	.avatar-fallback {
		position: relative;
		z-index: 1;
		width: 100%;
		height: 100%;
		border-radius: 9999px;
		object-fit: cover;
		box-shadow:
			0 0 0 4px var(--color-background),
			0 0 0 6px color-mix(in oklab, var(--color-primary) 75%, transparent);
		transition:
			transform 350ms cubic-bezier(0.32, 0.72, 0, 1),
			box-shadow 350ms ease;
	}

	.hero-avatar:hover .avatar-img,
	.hero-avatar:hover .avatar-fallback {
		transform: scale(1.035);
		box-shadow:
			0 0 0 4px var(--color-background),
			0 0 0 7px var(--color-primary);
	}

	.hero-avatar:hover .avatar-glow {
		opacity: 0.9;
	}

	.avatar-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		background: color-mix(in oklab, var(--color-primary) 88%, transparent);
		color: var(--color-primary-foreground);
		font-weight: 700;
		font-size: clamp(2rem, 3vw + 1rem, 3rem);
		letter-spacing: -0.03em;
	}

	@media (prefers-reduced-motion: reduce) {
		.avatar-img,
		.avatar-fallback,
		.avatar-glow {
			transition: none;
		}
		.hero-avatar:hover .avatar-img,
		.hero-avatar:hover .avatar-fallback {
			transform: none;
		}
	}

	.hero-word {
		display: inline-block;
		white-space: nowrap;
	}

	/* Espacio entre palabras vía CSS — depender del text node " " entre spans falla cuando
	   algún minificador HTML colapsa whitespace entre inline elements. `.hero-word--glue`
	   se usa para puntuación (p. ej. coma) que debe pegarse a la palabra anterior. */
	.hero-word + .hero-word:not(.hero-word--glue) {
		margin-inline-start: 0.25em;
	}

	.hero-char {
		display: inline-block;
		opacity: 0;
		will-change: opacity;
	}

	.hero-cursor {
		display: inline-block;
		width: 0.08em;
		height: 0.85em;
		margin-left: 0.08em;
		vertical-align: -0.08em;
		background: var(--color-primary);
		border-radius: 2px;
		animation: hero-blink 0.9s step-end infinite;
	}

	.hero-cursor.is-done {
		animation: hero-cursor-out 0.45s cubic-bezier(0.32, 0.72, 0, 1) forwards;
	}

	@keyframes hero-blink {
		0%,
		50% {
			opacity: 1;
		}
		51%,
		100% {
			opacity: 0;
		}
	}

	@keyframes hero-cursor-out {
		to {
			opacity: 0;
			transform: scaleY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-char {
			opacity: 1;
		}
		.hero-cursor {
			display: none;
		}
	}
</style>

<script>
	type WindowWithHeroBound = Window & { __heroTypewriter?: boolean };

	async function runHeroTypewriter() {
		if (typeof window === 'undefined') return;
		const w = window as WindowWithHeroBound;

		const chars = document.querySelectorAll<HTMLElement>('.hero-char');
		const cursor = document.querySelector<HTMLElement>('.hero-cursor');
		if (chars.length === 0) return;

		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReduced) {
			chars.forEach((el) => (el.style.opacity = '1'));
			cursor?.remove();
			return;
		}

		if (w.__heroTypewriter) {
			chars.forEach((el) => (el.style.opacity = '1'));
			cursor?.classList.add('is-done');
			return;
		}
		w.__heroTypewriter = true;

		const { animate, stagger } = await import('motion');

		const animation = animate(
			Array.from(chars),
			{ opacity: [0, 1] },
			{
				duration: 0.01,
				ease: 'linear',
				delay: stagger(0.022, { startDelay: 0.25 })
			}
		);

		animation.finished
			.then(() => {
				setTimeout(() => cursor?.classList.add('is-done'), 900);
			})
			.catch(() => {
				cursor?.classList.add('is-done');
			});
	}

	document.addEventListener('astro:page-load', runHeroTypewriter);
</script>
