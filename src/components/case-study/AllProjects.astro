---
import Layout from '@layouts/Layout.astro';
import ProjectsGrid from '@components/ProjectsGrid.astro';
import Button from '@components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { getLocalizedCollection, cleanSlug } from '@/i18n/collections';
import { getLocaleUrl, useTranslations, type Locale } from '@/i18n/ui';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const { t } = useTranslations(locale);

const entries = await getLocalizedCollection('projects', locale);

const title = `${t('projects.allTitle')} — Juan Cutiva`;
const description = t('projects.allDescription', { count: entries.length });

const siteBase = (Astro.site ?? Astro.url).toString().replace(/\/$/, '');
const pageUrl = `${siteBase}${getLocaleUrl('/projects', locale)}`;

// ItemList. Cada entrada apunta al CreativeWork del case study (por @id).
const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	'@id': `${pageUrl}#projects-list`,
	name: t('projects.allTitle'),
	description,
	url: pageUrl,
	numberOfItems: entries.length,
	itemListOrder: 'https://schema.org/ItemListOrderAscending',
	itemListElement: entries.map((entry, index) => {
		const slug = cleanSlug(entry);
		const caseUrl = `${siteBase}${getLocaleUrl(`/projects/${slug}`, locale)}`;
		return {
			'@type': 'ListItem',
			position: index + 1,
			url: caseUrl,
			name: entry.data.title,
			item: {
				'@type': 'CreativeWork',
				'@id': `${caseUrl}#case-study`,
				name: entry.data.title,
				url: caseUrl,
				description: entry.data.description
			}
		};
	})
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: t('nav.home'),
			item: `${siteBase}${getLocaleUrl('/', locale)}`
		},
		{ '@type': 'ListItem', position: 2, name: t('nav.projects'), item: pageUrl }
	]
};
---

<Layout title={title} description={description} lang={locale}>
	<script
		slot="head"
		type="application/ld+json"
		is:inline
		set:html={JSON.stringify(itemListSchema)}
	/>
	<script
		slot="head"
		type="application/ld+json"
		is:inline
		set:html={JSON.stringify(breadcrumbSchema)}
	/>

	<article class="mx-auto max-w-6xl px-5 py-16 sm:px-6 sm:py-20">
		<nav aria-label={t('nav.secondary')} class="text-muted mb-8 font-mono text-xs">
			<a
				href={getLocaleUrl('/#projects', locale)}
				class="hover:text-foreground inline-flex items-center gap-1 transition-colors"
			>
				<Icon name="lucide:arrow-left" class="h-3 w-3" aria-hidden="true" />
				{t('nav.home')}
			</a>
		</nav>

		<header class="max-w-2xl space-y-5">
			<p class="text-eyebrow text-primary">{t('projects.eyebrow')}</p>
			<h1 class="text-display-1 text-foreground text-balance">
				{t('projects.allTitle')}
			</h1>
			<p class="text-muted text-lede max-w-[62ch] text-pretty">
				{t('projects.allDescription', { count: entries.length })}
			</p>
		</header>

		<div class="mt-14">
			<ProjectsGrid entries={entries} sharedTransition locale={locale} />
		</div>

		<footer
			class="border-border mt-16 flex flex-col gap-4 border-t pt-10 sm:flex-row sm:items-center sm:justify-between"
		>
			<Button as="a" href={getLocaleUrl('/', locale)} variant="ghost">
				<Icon name="lucide:arrow-left" class="h-4 w-4" aria-hidden="true" />
				{t('404.backHome')}
			</Button>
			<Button as="a" href={getLocaleUrl('/contact', locale)} variant="primary">
				{t('caseStudy.contactCta')}
				<Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
			</Button>
		</footer>
	</article>
</Layout>
