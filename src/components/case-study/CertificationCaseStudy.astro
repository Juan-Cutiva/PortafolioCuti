---
import Layout from '@layouts/Layout.astro';
import Button from '@components/ui/Button.astro';
import CaseStudyHeader from '@components/CaseStudyHeader.astro';
import { Icon } from 'astro-icon/components';
import { render, type CollectionEntry } from 'astro:content';
import { cleanSlug } from '@/i18n/collections';
import { getLocaleUrl, useTranslations, type Locale } from '@/i18n/ui';

interface Props {
	entry: CollectionEntry<'certifications'>;
	locale: Locale;
}

const { entry, locale } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const { t } = useTranslations(locale);
const slug = cleanSlug(entry);

const title = `${data.name} — ${data.issuer}`;
const fallbackDescription = t('caseStudy.emittedBy', { issuer: data.issuer });
const description = data.description ?? fallbackDescription;
const ogImage = `/api/og?type=certification&slug=${slug}`;

const siteBase = (Astro.site ?? Astro.url).toString().replace(/\/$/, '');
const pageUrl = `${siteBase}${getLocaleUrl(`/certifications/${slug}`, locale)}`;

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: t('nav.home'),
			item: `${siteBase}${getLocaleUrl('/', locale)}`
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: t('nav.education'),
			item: `${siteBase}${getLocaleUrl('/#education', locale)}`
		},
		{ '@type': 'ListItem', position: 3, name: data.name, item: pageUrl }
	]
};

const nowIso = new Date().toISOString();

// EducationalOccupationalCredential es el tipo oficial para certificaciones. Ata al
// Person (autor) y al emisor (`recognizedBy`) para cruzar el grafo.
const credentialSchema = {
	'@context': 'https://schema.org',
	'@type': 'EducationalOccupationalCredential',
	'@id': `${pageUrl}#credential`,
	name: data.name,
	description,
	url: pageUrl,
	inLanguage: locale === 'en' ? 'en' : 'es-CO',
	credentialCategory: data.meta?.type ?? 'course',
	dateModified: nowIso,
	author: { '@id': `${siteBase}/#person` },
	recognizedBy: { '@type': 'Organization', name: data.issuer },
	...(data.url ? { sameAs: data.url } : {})
};
---

<Layout
	title={title}
	description={description}
	image={ogImage}
	ogType="article"
	lang={locale}
	article={{
		section: t('caseStudy.certification'),
		modifiedTime: nowIso,
		tags: [data.issuer]
	}}
>
	<script
		slot="head"
		type="application/ld+json"
		is:inline
		set:html={JSON.stringify(breadcrumbSchema)}
	/>
	<script
		slot="head"
		type="application/ld+json"
		is:inline
		set:html={JSON.stringify(credentialSchema)}
	/>

	<article class="mx-auto max-w-3xl px-5 py-16 sm:px-6 sm:py-24">
		<CaseStudyHeader
			breadcrumb={{
				href: getLocaleUrl('/#education', locale),
				label: t('caseStudy.backEducation')
			}}
			eyebrow={t('caseStudy.certification')}
			eyebrowTone="accent"
			title={data.name}
			description={description}
			primaryButton={
				data.url
					? {
							href: data.url,
							label: t('caseStudy.viewCertificate'),
							variant: 'primary',
							icon: 'lucide:external-link'
						}
					: undefined
			}
			badge={{ icon: data.icon, label: data.issuer }}
			image={data.image}
			imageFit="contain"
			pdf={data.pdf}
			imageCaption={t('caseStudy.emittedBy', { issuer: data.issuer })}
			meta={data.meta}
		/>

		<div class="case-study-prose mt-14">
			<Content />
		</div>

		<footer
			class="border-border mt-16 flex flex-col gap-4 border-t pt-10 sm:flex-row sm:items-center sm:justify-between"
		>
			<Button as="a" href={getLocaleUrl('/#education', locale)} variant="ghost">
				<Icon name="lucide:arrow-left" class="h-4 w-4" aria-hidden="true" />
				{t('caseStudy.backToEducation')}
			</Button>
			{
				data.url && (
					<Button
						as="a"
						href={data.url}
						variant="accent"
						rel="noopener noreferrer external"
						target="_blank"
					>
						{t('caseStudy.viewCertificateOfficial')}
						<Icon name="lucide:external-link" class="h-4 w-4" aria-hidden="true" />
					</Button>
				)
			}
		</footer>
	</article>
</Layout>
