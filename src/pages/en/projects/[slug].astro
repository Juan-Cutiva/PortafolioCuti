---
import ProjectCaseStudy from '@components/case-study/ProjectCaseStudy.astro';
import { getLocalizedCollection, cleanSlug } from '@/i18n/collections';
import type { CollectionEntry } from 'astro:content';

// Rutas en inglés: prerenderizadas por cada entrada con prefijo `en/` en `src/content/projects/`.
export const prerender = true;

export async function getStaticPaths() {
	const entries = await getLocalizedCollection('projects', 'en');
	return entries.map((entry) => ({
		params: { slug: cleanSlug(entry) },
		props: { entry }
	}));
}

interface Props {
	entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
---

<ProjectCaseStudy entry={entry} locale="en" />
