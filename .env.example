# Variables de entorno públicas del sitio. Copiar a `.env` (gitignored) y completar.

# URL canónica del sitio en producción. Obligatoria: el sitemap, los `<link rel="canonical">`
# y los meta Open Graph dependen de este valor. Sin ella el sitio despliega con el placeholder
# y las previews sociales quedan rotas.
PUBLIC_SITE_URL="https://portafolio-cuti.vercel.app"
